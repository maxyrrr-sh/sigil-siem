# Managed by Ansible — Sigil edge (TLS termination, SPA + API reverse proxy).
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name {{ domain }};

    location = /nginx-health { return 200 "ok\n"; add_header Content-Type text/plain; }
    location / { return 301 https://$host$request_uri; }   # force HTTPS
}

server {
    # Ubuntu 24.04 ships nginx 1.24, which predates the standalone
    # `http2 on;` directive (nginx 1.25.1+) — use the listen-param form.
    listen 443 ssl http2 default_server;
    listen [::]:443 ssl http2 default_server;
    server_name {{ domain }};

    ssl_certificate     {{ tls_dir }}/cert.pem;
    ssl_certificate_key {{ tls_dir }}/key.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options          "SAMEORIGIN" always;
    add_header X-Content-Type-Options   "nosniff" always;
    add_header Referrer-Policy          "strict-origin-when-cross-origin" always;

    client_max_body_size 16m;
    gzip on;
    gzip_types text/plain text/css application/json application/javascript application/xml image/svg+xml;

    root /var/www/sigil;
    index index.html;

    location = /nginx-health { return 200 "ok\n"; add_header Content-Type text/plain; }

    # API + Server-Sent-Events stream → the sigil core.
    location /api/ {
        proxy_pass http://{{ sigil_api_addr }};
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection        "";       # keep upstream keep-alive
        proxy_buffering off;                          # SSE: /api/v1/stream/alerts
        proxy_read_timeout 3600s;
    }

    # Unauthenticated liveness passthrough (handy for external checks).
    location = /health {
        proxy_pass http://{{ sigil_api_addr }}/health;
        proxy_set_header Host $host;
    }

    # Everything else → the static Svelte SPA.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
